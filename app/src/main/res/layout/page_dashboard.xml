<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/padding_large">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="健康数据看板"
        android:textColor="@color/textPrimary"
        android:textSize="@dimen/text_subtitle"
        android:textStyle="bold"
        android:paddingBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:id="@+id/stepsCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="14dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="步数"
                android:textColor="@color/textSecondary"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/stepsValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/accent"
                android:textSize="@dimen/text_metric"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/caloriesCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="14dp"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="消耗"
                android:textColor="@color/textSecondary"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/caloriesValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/textPrimary"
                android:textSize="@dimen/text_metric"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:id="@+id/heartRateCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="14dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="心率"
                android:textColor="@color/textSecondary"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/heartRateValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/coral"
                android:textSize="@dimen/text_metric"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sleepCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="14dp"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="睡眠"
                android:textColor="@color/textSecondary"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/sleepValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/primaryDark"
                android:textSize="@dimen/text_metric"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/sourceView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/textHint"
        android:textSize="11sp"
        android:paddingBottom="12dp" />

    <Button
        android:id="@+id/connectBtn"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="连接健康应用"
        android:textColor="@color/white"
        android:backgroundTint="@color/primary" />

    <Button
        android:id="@+id/refreshDashboardBtn"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="立即同步"
        android:textColor="@color/white"
        android:backgroundTint="@color/primary"
        android:layout_marginTop="8dp" />

</LinearLayout>
