<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\uD83D\uDCCA 健康数据看板"
        android:textColor="@color/text_primary_light"
        android:textSize="@dimen/text_headline"
        android:textStyle="bold"
        android:paddingBottom="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:id="@+id/stepsCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_bg_rounded"
            android:elevation="8dp"
            android:padding="@dimen/padding_xlarge"
            android:layout_marginEnd="6dp">
            <TextView style="@style/MetricLabel" android:text="\uD83D\uDC63 步数" android:textColor="@color/text_secondary_light" />
            <TextView
                android:id="@+id/stepsValue"
                style="@style/MetricValue.Large"
                android:text="--"
                android:textColor="@color/aurora_green" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="步"
                android:textColor="@color/text_hint_light"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/caloriesCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_bg_rounded"
            android:elevation="8dp"
            android:padding="@dimen/padding_xlarge"
            android:layout_marginStart="6dp">
            <TextView style="@style/MetricLabel" android:text="\uD83D\uDD25 消耗" android:textColor="@color/text_secondary_light" />
            <TextView
                android:id="@+id/caloriesValue"
                style="@style/MetricValue.Large"
                android:text="--"
                android:textColor="@color/text_primary_light" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="kcal"
                android:textColor="@color/text_hint_light"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:id="@+id/heartRateCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_bg_rounded"
            android:elevation="8dp"
            android:padding="@dimen/padding_xlarge"
            android:layout_marginEnd="6dp">
            <TextView style="@style/MetricLabel" android:text="\u2764 心率" android:textColor="@color/text_secondary_light" />
            <TextView
                android:id="@+id/heartRateValue"
                style="@style/MetricValue.Large"
                android:text="--"
                android:textColor="@color/coral_orange" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="bpm"
                android:textColor="@color/text_hint_light"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sleepCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_bg_rounded"
            android:elevation="8dp"
            android:padding="@dimen/padding_xlarge"
            android:layout_marginStart="6dp">
            <TextView style="@style/MetricLabel" android:text="\uD83C\uDF19 睡眠" android:textColor="@color/text_secondary_light" />
            <TextView
                android:id="@+id/sleepValue"
                style="@style/MetricValue.Large"
                android:text="--"
                android:textColor="@color/deep_sea_blue" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="小时"
                android:textColor="@color/text_hint_light"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/sourceView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_hint_light"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <Button
        android:id="@+id/connectBtn"
        style="@style/AccentButton"
        android:text="\uD83D\uDCF6 连接健康应用"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/refreshDashboardBtn"
        style="@style/PrimaryButton"
        android:text="\uD83D\uDD04 立即同步" />

</LinearLayout>