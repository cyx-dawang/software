<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/posterRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\uD83C\uDFA8 成就海报预览"
        android:textColor="@color/text_primary_light"
        android:textSize="@dimen/text_headline"
        android:textStyle="bold"
        android:paddingBottom="20dp" />

    <LinearLayout
        android:id="@+id/posterCard"
        android:layout_width="match_parent"
        android:layout_height="@dimen/poster_height"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/header_bg"
        android:elevation="12dp"
        android:padding="@dimen/padding_xxlarge">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\uD83C\uDFC6"
            android:textSize="44sp"
            android:paddingBottom="12dp" />

        <TextView
            android:id="@+id/posterTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="运动成就"
            android:textColor="@color/white"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/posterDistance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-- KM"
            android:textColor="@color/aurora_green"
            android:textSize="56sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="12dp" />

        <View
            android:layout_width="80dp"
            android:layout_height="3dp"
            android:background="@color/aurora_green"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/posterPace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/white"
            android:textSize="@dimen/text_subtitle"
            android:gravity="center" />

        <TextView
            android:id="@+id/posterName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#B4C8DC"
            android:textSize="@dimen/text_body"
            android:gravity="center"
            android:paddingTop="20dp" />
    </LinearLayout>

    <Button
        android:id="@+id/posterShareBtn"
        style="@style/AccentButton"
        android:text="\uD83D\uDCF2 分享到社交平台"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/posterBackBtn"
        style="@style/OutlineButton"
        android:text="\u2190 返回"
        android:layout_marginTop="12dp" />

</LinearLayout>