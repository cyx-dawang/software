<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/trainingRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\uD83D\uDCC5 个性化运动计划"
        android:textColor="@color/text_primary_light"
        android:textSize="@dimen/text_headline"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/trainingPeriod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_secondary_light"
        android:textSize="@dimen/text_body"
        android:paddingBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:orientation="horizontal"
        android:background="@color/divider_light"
        android:layout_marginBottom="16dp">

        <View
            android:id="@+id/progressFill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/progress_bar" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/dateSelector"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/dayDetailCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg_rounded"
        android:elevation="8dp"
        android:padding="@dimen/padding_xlarge"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/dayExerciseType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/deep_sea_blue"
            android:textSize="@dimen/text_subtitle"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:background="@color/aurora_green"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/dayIntensity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/coral_orange"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                android:paddingEnd="20dp" />
            <TextView
                android:id="@+id/dayDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_primary_light"
                android:textSize="@dimen/text_body" />
        </LinearLayout>

        <TextView
            android:id="@+id/dayDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary_light"
            android:textSize="@dimen/text_body"
            android:paddingBottom="16dp" />

        <Button
            android:id="@+id/dayStartBtn"
            style="@style/AccentButton"
            android:text="\u25B6 开始运动" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/planList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <Button
        android:id="@+id/createPlanBtn"
        style="@style/AccentButton"
        android:text="\uD83C\uDFAF 生成我的初始运动计划" />

</LinearLayout>