<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reportRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\uD83C\uDFC6"
            android:textSize="48sp"
            android:paddingBottom="8dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="运动总结报告"
            android:textColor="@color/text_primary_light"
            android:textSize="@dimen/text_headline"
            android:textStyle="bold"
            android:gravity="center" />
        <TextView
            android:id="@+id/reportDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary_light"
            android:textSize="@dimen/text_body"
            android:gravity="center"
            android:paddingTop="6dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_bg_rounded"
            android:elevation="8dp"
            android:padding="@dimen/padding_xlarge"
            android:layout_marginEnd="6dp">
            <TextView style="@style/MetricLabel" android:text="\uD83C\uDFC3 总距离" android:textColor="@color/text_secondary_light" />
            <TextView
                android:id="@+id/reportDistance"
                style="@style/MetricValue.Large"
                android:text="--"
                android:textColor="@color/aurora_green" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_bg_rounded"
            android:elevation="8dp"
            android:padding="@dimen/padding_xlarge"
            android:layout_marginStart="6dp">
            <TextView style="@style/MetricLabel" android:text="\u23F1 总时长" android:textColor="@color/text_secondary_light" />
            <TextView
                android:id="@+id/reportDuration"
                style="@style/MetricValue.Large"
                android:text="--:--"
                android:textColor="@color/deep_sea_blue" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_bg_rounded"
            android:elevation="8dp"
            android:padding="@dimen/padding_xlarge"
            android:layout_marginEnd="6dp">
            <TextView style="@style/MetricLabel" android:text="\u26A1 平均配速" android:textColor="@color/text_secondary_light" />
            <TextView
                android:id="@+id/reportPace"
                style="@style/MetricValue"
                android:text="--'--&quot;"
                android:textColor="@color/coral_orange" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_bg_rounded"
            android:elevation="8dp"
            android:padding="@dimen/padding_xlarge"
            android:layout_marginStart="6dp">
            <TextView style="@style/MetricLabel" android:text="\uD83D\uDD25 消耗" android:textColor="@color/text_secondary_light" />
            <TextView
                android:id="@+id/reportCalories"
                style="@style/MetricValue"
                android:text="--"
                android:textColor="@color/text_primary_light" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg_rounded"
        android:elevation="8dp"
        android:padding="@dimen/padding_xlarge"
        android:layout_marginBottom="16dp">
        <TextView
            android:id="@+id/reportSteps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\uD83D\uDC63 步数: -- 步"
            android:textColor="@color/text_primary_light"
            android:textSize="@dimen/text_body"
            android:paddingBottom="6dp" />
        <TextView
            android:id="@+id/reportSpeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\uD83D\uDCC8 平均速度: -- km/h"
            android:textColor="@color/text_secondary_light"
            android:textSize="@dimen/text_body" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/reportButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/reportSaveBtn"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/save_record"
            style="@style/AccentButton"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/reportDiscardBtn"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/discard_record"
            style="@style/DangerButton"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <Button
        android:id="@+id/reportAgainBtn"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="\uD83D\uDD04 再跑一次"
        style="@style/OutlineButton" />

</LinearLayout>